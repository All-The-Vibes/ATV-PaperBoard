<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title | e }}</title>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
  />
  <style>
    /* ── Token overrides injected by atv-paperboard render layer ──
       Pico v2 declares its theme vars under `[data-theme=light]`. The
       cascade order between Pico's external stylesheet and our inline
       `<style>` is racy (Pico can finish loading after our block parses,
       which causes Pico's values to win even at equal specificity).
       `!important` removes the race entirely: regardless of fetch order,
       our DESIGN.md tokens always win for the variables we declare.
       Pico's internal `--pico-*` variables that we don't override remain
       at their defaults — we only force the ones the DESIGN.md owns. */
    html[data-theme="light"], :root {
{% for var, value in tokens.items() %}
      {{ var }}: {{ value }} !important;
{% endfor %}
      /* Bind Pico's per-heading color vars to --pico-primary so DESIGN.md
         `colors.primary` reaches h1..h6 (Pico defaults them to a gray ramp). */
      --pico-h1-color: var(--pico-primary) !important;
      --pico-h2-color: var(--pico-primary) !important;
      --pico-h3-color: var(--pico-primary) !important;
      --pico-h4-color: var(--pico-primary) !important;
      --pico-h5-color: var(--pico-primary) !important;
      --pico-h6-color: var(--pico-primary) !important;
    }

    body {
      padding: 0;
      margin: 0;
      background-color: var(--pico-background-color);
    }

    .pb-content {
      max-width: 1024px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .pb-footer {
      margin-top: 3rem;
      padding: 1rem;
      border-top: 1px solid var(--pico-muted-border-color, #e0e0e0);
      font-size: 0.75rem;
      color: var(--pico-muted-color, #666);
      text-align: center;
    }

    .pb-footer a {
      color: inherit;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <main class="pb-content">
    {{ body_html }}
  </main>

  <footer class="pb-footer">
    Generated by <strong>atv-paperboard</strong> &mdash;
    <a href="{{ design_md_path | e }}" target="_blank" rel="noopener">DESIGN.md</a>
  </footer>
</body>
</html>
