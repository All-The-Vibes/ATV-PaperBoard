<!DOCTYPE html>
<html lang="en" data-theme="atv">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ title | e }}</title>
<style>
  :root {
    --bg: {{ tokens.get('--color-background', '#08090a') }};
    --bg-zebra: #0a0b0d;
    --canvas-hero: #050507;
    --surface: {{ tokens.get('--color-surface', '#0e0f12') }};
    --surface-2: #14151a;
    --surface-3: #1a1b21;
    --code-bg: #06060a;
    --line: rgba(255,255,255,0.06);
    --line-strong: rgba(255,255,255,0.14);
    --line-bright: rgba(255,255,255,0.22);
    --text-1: {{ tokens.get('--color-foreground', '#f7f8f8') }};
    --text-2: #d0d6e0;
    --text-3: {{ tokens.get('--color-muted', '#8a8f98') }};
    --text-4: #62666d;
    --accent: {{ tokens.get('--color-primary', '#7170ff') }};
    --accent-bg: rgba(94,106,210,0.10);
    --accent-line: rgba(113,112,255,0.32);
    --rose: {{ tokens.get('--color-accent', '#f43f5e') }};
    --success: {{ tokens.get('--color-success', '#34d399') }};
    --danger: {{ tokens.get('--color-danger', '#fb7185') }};
    --glow-blue: rgba(94,106,210,0.22);
    --glow-rose: rgba(244,63,94,0.14);
    --glow-cyan: rgba(34,211,238,0.10);
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-fast: cubic-bezier(0.4, 0, 0.2, 1);
  }

  * { box-sizing: border-box; }
  html, body { background: var(--bg); }
  body {
    margin: 0;
    font-family: "Inter", "Geist", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-feature-settings: "cv01", "ss03", "ss01";
    color: var(--text-1);
    font-size: 15px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .mono { font-family: "Geist Mono", "JetBrains Mono", "SF Mono", Menlo, Consolas, monospace; font-feature-settings: "tnum", "ss01"; }
  .small { font-size: 11.5px; }
  .muted { color: var(--text-3); }
  .dim { color: var(--text-4); }
  a { color: var(--text-1); text-decoration: none; border-bottom: 1px solid var(--line-strong); transition: border-color 180ms var(--ease); }
  a:hover { border-color: var(--accent); }

  code {
    font-family: "Geist Mono", "JetBrains Mono", monospace;
    font-size: 0.875em;
    background: rgba(255,255,255,0.04);
    padding: 1.5px 6px;
    border-radius: 4px;
    color: var(--text-2);
    border: 1px solid var(--line);
  }

  /* Topbar */
  .topbar {
    position: sticky; top: 0; z-index: 50;
    height: 52px;
    backdrop-filter: blur(14px);
    background: rgba(8,9,10,0.78);
    border-bottom: 1px solid var(--line);
    display: flex; align-items: center;
    padding: 0 32px;
    font-size: 13px;
  }
  .topbar .brand {
    display: inline-flex; align-items: center; gap: 9px;
    font-weight: 510; letter-spacing: -0.01em; color: var(--text-1);
  }
  .topbar .brand .glyph {
    width: 14px; height: 14px;
    border-radius: 3px;
    background: linear-gradient(135deg, var(--accent), #5e6ad2);
  }
  .topbar .crumb { color: var(--text-3); margin-left: 18px; }
  .topbar .crumb .sep { margin: 0 8px; color: var(--text-4); }
  .topbar .crumb .cur { color: var(--text-1); }
  .topbar .spacer { flex: 1; }
  .topbar .tag {
    color: var(--text-3); font-size: 11.5px;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 3px 10px;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .topbar .tag::before {
    content: ""; width: 5px; height: 5px; border-radius: 50%;
    background: var(--success); box-shadow: 0 0 8px rgba(52,211,153,0.55);
  }

  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 32px; }

  /* Hero */
  .hero { position: relative; padding: 112px 0 80px; overflow: hidden; }
  .hero::before {
    content: ""; position: absolute; inset: 0;
    background:
      radial-gradient(900px circle at 12% 8%, var(--glow-blue), transparent 60%),
      radial-gradient(680px circle at 88% 4%, var(--glow-rose), transparent 55%);
    pointer-events: none;
    mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 100%);
  }
  .hero .eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    color: var(--text-3); font-family: "Geist Mono", monospace;
    font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.12em;
    margin-bottom: 36px;
  }
  .hero .eyebrow .bar { width: 28px; height: 1px; background: var(--line-strong); }
  .hero h1 {
    margin: 0 0 24px;
    font-size: clamp(44px, 6vw, 72px);
    font-weight: 510; letter-spacing: -0.04em; line-height: 1.04;
    color: var(--text-1); max-width: 22ch;
  }
  .hero h1 .into { color: var(--text-3); }
  .hero .sub {
    color: var(--text-2); font-size: 18px; line-height: 1.55;
    max-width: 62ch; margin: 0 0 44px;
  }
  .hero-meta {
    display: flex; gap: 32px; flex-wrap: wrap;
    padding-top: 22px; border-top: 1px solid var(--line);
    font-family: "Geist Mono", monospace; font-size: 11.5px;
    color: var(--text-3); text-transform: uppercase; letter-spacing: 0.08em;
  }
  .hero-meta .item { display: inline-flex; gap: 10px; align-items: baseline; }
  .hero-meta .item .v { color: var(--text-1); font-size: 13px; letter-spacing: 0; text-transform: none; font-weight: 510; }

  /* Sections */
  .sec { padding: 88px 0; border-top: 1px solid var(--line); position: relative; }
  .sec.zebra { background: var(--bg-zebra); }
  .sec.tight { padding: 64px 0; }
  .sec-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 36px; flex-wrap: wrap; }
  .sec-head .num { font-family: "Geist Mono", monospace; font-size: 12px; color: var(--text-4); }
  .sec-head .eyebrow {
    font-family: "Geist Mono", monospace; font-size: 11.5px;
    color: var(--text-3); text-transform: uppercase; letter-spacing: 0.12em;
  }
  .sec-head h2 {
    margin: 0; font-size: 34px; font-weight: 510; letter-spacing: -0.025em;
    color: var(--text-1); flex-basis: 100%; line-height: 1.1; max-width: 24ch;
  }
  .sec-head .aside {
    margin-left: auto; border: 1px solid var(--line); border-radius: 999px;
    padding: 3px 11px; font-family: "Geist Mono", monospace;
    font-size: 11px; color: var(--text-3); align-self: center;
  }
  .sec-lede { color: var(--text-2); font-size: 17px; max-width: 68ch; margin: -8px 0 36px; line-height: 1.55; }

  /* Stack list */
  .stack-list { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); overflow: hidden; }
  .stack-row {
    display: grid; grid-template-columns: 280px 1fr 1.1fr;
    gap: 24px; padding: 18px 22px;
    border-bottom: 1px solid var(--line);
    align-items: start; transition: background 180ms var(--ease);
  }
  .stack-row:last-child { border-bottom: 0; }
  .stack-row:hover { background: rgba(255,255,255,0.02); }
  .stack-name { display: flex; flex-direction: column; gap: 8px; align-items: flex-start; }
  .stack-name .mono { font-size: 13px; color: var(--text-1); }
  .stack-tag {
    font-family: "Geist Mono", monospace; font-size: 10px;
    text-transform: uppercase; letter-spacing: 0.08em;
    padding: 2px 8px; border-radius: 4px;
    border: 1px solid var(--line); color: var(--text-3);
  }
  .stack-why, .stack-fix { font-size: 14px; color: var(--text-2); line-height: 1.55; }
  .stack-fix { color: var(--text-3); }
  @media (max-width: 820px) { .stack-row { grid-template-columns: 1fr; gap: 10px; padding: 16px 18px; } }

  /* Dep list */
  .dep-list { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); overflow: hidden; }
  .dep-row {
    display: grid; grid-template-columns: 220px 1fr 1.6fr 90px;
    gap: 20px; padding: 16px 22px;
    border-bottom: 1px solid var(--line);
    align-items: center; transition: background 180ms var(--ease);
  }
  .dep-row:last-child { border-bottom: 0; }
  .dep-row:hover { background: rgba(255,255,255,0.02); }
  .dep-col-name { display: flex; flex-direction: column; gap: 6px; align-items: flex-start; }
  .dep-name { font-size: 13px; color: var(--text-1); }
  .dep-tag {
    font-family: "Geist Mono", monospace; font-size: 9.5px;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 2px 7px; border-radius: 4px; border: 1px solid var(--line); color: var(--text-3);
  }
  .dep-tag-required { border-color: var(--accent-line); color: var(--accent); }
  .dep-tag-transitive { border-color: var(--line-strong); color: var(--text-3); }
  .dep-col-role { font-family: "Geist Mono", monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-3); }
  .dep-col-why { font-size: 13.5px; color: var(--text-2); line-height: 1.5; }
  .dep-col-ver { font-size: 11.5px; color: var(--text-4); text-align: right; }
  @media (max-width: 820px) { .dep-row { grid-template-columns: 1fr; gap: 8px; padding: 16px 18px; } .dep-col-ver { text-align: left; } }

  /* Q list */
  .q-list { border: 1px solid var(--line); border-radius: 12px; overflow: hidden; background: var(--surface); }
  .q-row {
    display: grid; grid-template-columns: 64px 1fr;
    padding: 22px 24px; border-bottom: 1px solid var(--line);
    align-items: start; transition: background 180ms var(--ease);
  }
  .q-row:last-child { border-bottom: 0; }
  .q-row:hover { background: rgba(255,255,255,0.02); }
  .q-num { color: var(--text-4); font-size: 12px; padding-top: 2px; }
  .q-body h4 { margin: 0 0 6px; font-size: 14px; font-weight: 510; color: var(--text-1); }
  .q-body p { margin: 0; font-size: 14px; color: var(--text-2); max-width: 70ch; }

  /* Steps */
  .steps { border-left: 1px solid var(--line); padding-left: 0; }
  .step-row {
    display: grid; grid-template-columns: 64px 1fr;
    padding: 14px 0 14px 22px;
    border-left: 1px solid transparent; margin-left: -1px;
    transition: border-color 180ms var(--ease); position: relative;
  }
  .step-row::before {
    content: ""; position: absolute; left: -4px; top: 22px;
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--surface-3); border: 1px solid var(--line-strong);
  }
  .step-row:hover { border-left-color: var(--line-bright); }
  .step-row:hover::before { background: var(--accent); border-color: var(--accent); }
  .step-num { font-size: 12px; color: var(--text-4); padding-top: 2px; }
  .step-title { font-size: 14.5px; font-weight: 510; color: var(--text-1); margin-bottom: 4px; }
  .step-desc { font-size: 13.5px; max-width: 64ch; line-height: 1.55; color: var(--text-3); }

  /* Code shell */
  .code-shell { border: 1px solid var(--line); border-radius: 12px; overflow: hidden; background: var(--code-bg); margin-top: 8px; }
  .code-bar { display: flex; align-items: center; gap: 12px; padding: 10px 16px; background: var(--surface-2); border-bottom: 1px solid var(--line); }
  .code-dots { display: flex; gap: 6px; }
  .code-dots i { width: 11px; height: 11px; border-radius: 50%; display: inline-block; opacity: 0.85; }
  .code-lang { font-family: "Geist Mono", monospace; font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.1em; margin-left: auto; }
  pre.code { margin: 0; padding: 20px 24px; overflow-x: auto; font-family: "Geist Mono", "JetBrains Mono", Menlo, monospace; font-size: 13px; line-height: 1.6; color: var(--text-2); }

  /* Props table */
  table.props { width: 100%; border-collapse: collapse; border: 1px solid var(--line); border-radius: 12px; overflow: hidden; background: var(--surface); }
  table.props th { text-align: left; padding: 12px 18px; font-family: "Geist Mono", monospace; font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-3); background: var(--surface-2); border-bottom: 1px solid var(--line); font-weight: 500; }
  table.props td { padding: 16px 18px; border-bottom: 1px solid var(--line); vertical-align: top; font-size: 14px; color: var(--text-2); }
  table.props tr:last-child td { border-bottom: 0; }
  .prop-name { font-weight: 600; color: var(--text-1); }
  .type-pill { display: inline-block; padding: 2px 9px; border: 1px solid var(--line-strong); border-radius: 4px; font-size: 11.5px; color: var(--text-2); }

  /* Color strip */
  .color-strip { display: grid; grid-template-columns: repeat(6, 1fr); gap: 1px; border: 1px solid var(--line); background: var(--line); border-radius: 12px; overflow: hidden; }
  .color-cell { background: var(--surface); padding: 22px 18px; display: flex; flex-direction: column; gap: 12px; }
  .color-swatch { width: 100%; height: 64px; border-radius: 6px; border: 1px solid var(--line-strong); }
  .color-meta { display: flex; flex-direction: column; gap: 3px; }
  .color-hex { font-size: 11.5px; color: var(--text-1); }
  .color-name { font-size: 13px; font-weight: 510; color: var(--text-1); }
  .color-role { font-size: 11.5px; color: var(--text-3); line-height: 1.4; }
  @media (max-width: 820px) { .color-strip { grid-template-columns: repeat(2, 1fr); } }

  /* Fit chips */
  .fit-row { display: flex; flex-wrap: wrap; gap: 6px; }
  .fit { display: inline-flex; align-items: center; gap: 7px; padding: 5px 12px; border-radius: 999px; background: var(--surface); border: 1px solid var(--line); color: var(--text-2); font-size: 12.5px; font-weight: 500; }
  .fit::before { content: ""; width: 4px; height: 4px; border-radius: 50%; background: var(--success); }
  .fit.avoid::before { background: var(--danger); }
  .fit.avoid { color: var(--text-3); }

  /* Anti-pattern */
  .anti { background: var(--surface); border: 1px solid var(--line); border-radius: 12px; padding: 22px 26px; position: relative; }
  .anti::before { content: "DO NOT"; position: absolute; top: 18px; right: 22px; font-family: "Geist Mono", monospace; font-size: 10.5px; color: var(--text-4); letter-spacing: 0.12em; }
  .anti ul { margin: 0; padding-left: 20px; color: var(--text-2); }
  .anti li { font-size: 14px; margin: 7px 0; line-height: 1.5; max-width: 68ch; }
  .anti li::marker { color: var(--text-4); }

  /* Checklist */
  .check-list { border: 1px solid var(--line); border-radius: 12px; background: var(--surface); overflow: hidden; }
  .chk { display: flex; gap: 12px; align-items: flex-start; padding: 13px 22px; border-bottom: 1px solid var(--line); font-size: 13.5px; color: var(--text-2); }
  .chk:last-child { border-bottom: 0; }
  .chk-mark { color: var(--text-4); font-family: "Geist Mono", monospace; margin-top: 1px; width: 12px; }

  /* Callout */
  .callout { margin-top: 24px; background: var(--accent-bg); border: 1px solid var(--accent-line); border-radius: 12px; padding: 22px 26px; }
  .callout h4 { margin: 0 0 10px; font-size: 14px; color: var(--text-1); font-weight: 510; }
  .callout ul { margin: 0; padding-left: 18px; color: var(--text-2); font-size: 14px; }
  .callout li { margin: 5px 0; }

  /* Status badges (for typed tables) */
  .badge { display: inline-block; padding: 2px 9px; border-radius: 4px; font-family: "Geist Mono", monospace; font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.08em; border: 1px solid var(--line); color: var(--text-3); }
  .badge.done, .badge.pass { border-color: rgba(52,211,153,0.35); color: var(--success); }
  .badge.fail, .badge.error { border-color: rgba(251,113,133,0.35); color: var(--danger); }
  .badge.in-progress, .badge.wip { border-color: rgba(113,112,255,0.35); color: var(--accent); }
  .badge.skip, .badge.pending { border-color: var(--line-strong); color: var(--text-3); }

  /* Subhead */
  .subhead { font-family: "Geist Mono", monospace; font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.12em; margin: 36px 0 14px; }

  /* File path */
  .file-path { display: inline-flex; align-items: center; gap: 8px; margin: 28px 0 0; padding: 6px 12px; background: var(--surface); border: 1px solid var(--line); border-radius: 6px; font-family: "Geist Mono", monospace; font-size: 12px; color: var(--text-2); }
  .file-path::before { content: ""; width: 6px; height: 6px; border-radius: 2px; background: var(--accent); }

  /* Foot */
  footer.foot { border-top: 1px solid var(--line); padding: 48px 0 64px; color: var(--text-3); font-size: 12.5px; }
  footer.foot .row { display: flex; gap: 28px; flex-wrap: wrap; align-items: baseline; }
  footer.foot .row .right { margin-left: auto; }
  footer.foot .mono { color: var(--text-4); font-size: 11.5px; }
</style>
</head>
<body>

<div class="topbar">
  <span class="brand"><span class="glyph"></span>{{ brand | default('atv-paperboard') | e }}</span>
  {% if breadcrumb %}<span class="crumb">{{ breadcrumb | safe }}</span>{% endif %}
  <span class="spacer"></span>
  <span class="tag">{{ status_tag | default('rendered') | e }}</span>
</div>

<div class="wrap">
  {{ body_html | safe }}

  <footer class="foot">
    <div class="row">
      <span>Generated by <strong>atv-paperboard</strong>.</span>
      <span class="right mono"><a href="{{ design_md_path | e }}" target="_blank" rel="noopener">DESIGN.md</a></span>
    </div>
  </footer>
</div>

</body>
</html>
