<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Paperboard Gallery</title>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
  />
  <style>
    /* ── Token overrides injected by atv-paperboard gallery layer ── */
    :root {
{% for var, value in tokens.items() %}
      {{ var }}: {{ value }};
{% endfor %}
    }

    body {
      padding: 0;
      margin: 0;
    }

    .pb-gallery-wrap {
      max-width: 1080px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .pb-gallery-header {
      border-bottom: 2px solid var(--pico-primary, #1A1A1A);
      margin-bottom: 2rem;
      padding-bottom: 1rem;
    }

    .pb-gallery-header h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--pico-primary, #1A1A1A);
      margin: 0 0 0.25rem;
    }

    .pb-gallery-meta {
      font-size: 0.8rem;
      color: var(--pico-muted-color, #64748B);
    }

    .pb-card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.25rem;
    }

    .pb-card {
      border: 2px solid var(--pico-primary, #1A1A1A);
      border-radius: 4px;
      padding: 1rem;
      background: var(--pico-background-color, #FAFAFA);
      transition: border-color 0.15s;
    }

    .pb-card:hover {
      border-color: var(--pico-contrast, #3B82F6);
    }

    .pb-card-title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--pico-primary, #1A1A1A);
      margin: 0 0 0.5rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .pb-card-row {
      font-size: 0.75rem;
      color: var(--pico-muted-color, #64748B);
      margin: 0.15rem 0;
    }

    .pb-badge {
      display: inline-block;
      padding: 0.1rem 0.4rem;
      border-radius: 2px;
      font-size: 0.7rem;
      font-weight: 600;
      background: var(--pico-contrast, #F59E0B);
      color: var(--pico-primary, #1A1A1A);
      margin-left: 0.25rem;
    }

    .pb-card-link {
      display: inline-block;
      margin-top: 0.75rem;
      font-size: 0.8rem;
      color: var(--pico-contrast, #3B82F6);
      text-decoration: underline;
    }

    .pb-empty {
      padding: 3rem 0;
      text-align: center;
      color: var(--pico-muted-color, #64748B);
    }

    .pb-footer {
      margin-top: 3rem;
      padding: 1rem 0;
      border-top: 1px solid var(--pico-muted-border-color, #E2E8F0);
      font-size: 0.75rem;
      color: var(--pico-muted-color, #64748B);
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="pb-gallery-wrap">
    <header class="pb-gallery-header">
      <h1>Paperboard Gallery</h1>
      <p class="pb-gallery-meta">
        {{ total }} artifact{% if total != 1 %}s{% endif %} &mdash; generated {{ generated_at | e }}
      </p>
    </header>

    {% if artifacts %}
    <div class="pb-card-grid">
      {% for art in artifacts %}
      <article class="pb-card">
        <h2 class="pb-card-title" title="{{ art.title | e }}">{{ art.title | e }}</h2>
        <p class="pb-card-row">
          <strong>Harness:</strong> {{ art.harness | e }}
          <span class="pb-badge">{{ art.tier | e }}</span>
        </p>
        {% if art.design %}
        <p class="pb-card-row">
          <strong>Design:</strong> {{ art.design | e | truncate(40, True) }}
        </p>
        {% endif %}
        {% if art.created_at %}
        <p class="pb-card-row">
          <strong>Created:</strong> {{ art.created_at | e | truncate(25, True) }}
        </p>
        {% endif %}
        {% if art.html_exists %}
        <a class="pb-card-link" href="{{ art.html_name | e }}">Open artifact &rarr;</a>
        {% else %}
        <span class="pb-card-row">(HTML file not found)</span>
        {% endif %}
      </article>
      {% endfor %}
    </div>
    {% else %}
    <div class="pb-empty">
      <p>No artifacts found. Run <code>paperboard render</code> to create your first artifact.</p>
    </div>
    {% endif %}

    <footer class="pb-footer">
      Generated by <strong>atv-paperboard</strong> COMPOUND pillar
    </footer>
  </div>
</body>
</html>
