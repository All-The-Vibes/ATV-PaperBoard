<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title | e }}</title>
  <!-- Tailwind CDN (play.cdn.tailwindcss.com for dev; replace with bundled for prod) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- daisyUI via CDN -->
  <link
    href="https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css"
    rel="stylesheet"
    type="text/css"
  />
  <style>
    /* ── Token overrides injected by atv-paperboard render layer ──
       daisyUI declares its theme vars under `[data-theme=light]`. The
       inline-vs-external cascade race is the same problem Pico has —
       `!important` makes our DESIGN.md tokens unconditionally win. */
    html[data-theme="light"], :root {
{% for var, value in tokens.items() %}
      {{ var }}: {{ value }} !important;
{% endfor %}
    }

    body {
      background-color: var(--color-background, oklch(var(--b1, 100% 0 0)));
      color: var(--color-foreground, oklch(var(--bc, 20% 0.02 0)));
    }

    .pb-content {
      max-width: 1024px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    /* ── Document typography ──
       Tailwind's preflight reset strips default browser styling from
       semantic elements. Without explicit rules below, every <h2>, <ul>,
       <pre>, and <blockquote> rendered into `.pb-content` would collapse
       to base-size unstyled text. Each rule reads from the DESIGN.md
       tokens overridden above, so a `--design` swap actually flips the
       rendered surface. */
    .pb-content {
      color: var(--color-foreground, #1a1a1a);
      font-family: var(--font-body, system-ui, -apple-system, "Segoe UI", sans-serif);
      line-height: 1.65;
    }
    .pb-content h1,
    .pb-content h2,
    .pb-content h3,
    .pb-content h4,
    .pb-content h5,
    .pb-content h6 {
      color: var(--color-foreground, #111);
      font-family: var(--font-heading, var(--font-body, system-ui, sans-serif));
      font-weight: 600;
      letter-spacing: -0.015em;
      line-height: 1.2;
      margin-top: 2em;
      margin-bottom: 0.5em;
    }
    .pb-content h1 { font-size: 2.0rem; margin-top: 0.5em; }
    .pb-content h2 { font-size: 1.6rem; }
    .pb-content h3 { font-size: 1.3rem; }
    .pb-content h4 { font-size: 1.1rem; }
    .pb-content h5 { font-size: 1.0rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .pb-content h6 { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted, #666); }
    .pb-content p {
      margin: 0 0 1em 0;
      max-width: 65ch;
    }
    .pb-content a {
      color: var(--color-primary, #2563eb);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .pb-content a:hover { opacity: 0.8; }
    .pb-content ul,
    .pb-content ol {
      margin: 0 0 1em 0;
      padding-left: 1.5em;
    }
    .pb-content ul { list-style: disc outside; }
    .pb-content ol { list-style: decimal outside; }
    .pb-content li { margin: 0.25em 0; }
    .pb-content li > ul,
    .pb-content li > ol { margin: 0.25em 0; }
    .pb-content blockquote {
      margin: 1em 0;
      padding: 0.5em 1em;
      border-left: 3px solid var(--color-primary, #2563eb);
      color: var(--color-muted, #555);
      background: var(--color-surface, transparent);
    }
    .pb-content code {
      font-family: var(--font-mono, ui-monospace, "JetBrains Mono", Menlo, Consolas, monospace);
      font-size: 0.9em;
      padding: 0.15em 0.35em;
      border-radius: 4px;
      background: var(--color-surface, rgba(0,0,0,0.05));
      color: var(--color-foreground, inherit);
    }
    .pb-content pre {
      margin: 1em 0;
      padding: 1em;
      border-radius: 8px;
      overflow-x: auto;
      background: var(--color-surface, #f4f4f5);
      border: 1px solid var(--color-border, rgba(0,0,0,0.08));
      font-family: var(--font-mono, ui-monospace, "JetBrains Mono", Menlo, Consolas, monospace);
      font-size: 0.85em;
      line-height: 1.55;
    }
    .pb-content pre code {
      padding: 0;
      background: transparent;
      border-radius: 0;
      font-size: inherit;
    }
    .pb-content hr {
      margin: 2em 0;
      border: 0;
      border-top: 1px solid var(--color-border, rgba(0,0,0,0.1));
    }
    .pb-content table {
      border-collapse: collapse;
      margin: 1em 0;
      width: 100%;
      font-size: 0.95em;
    }
    .pb-content table th,
    .pb-content table td {
      padding: 0.5em 0.75em;
      border: 1px solid var(--color-border, rgba(0,0,0,0.12));
      text-align: left;
    }
    .pb-content table th {
      background: var(--color-surface, rgba(0,0,0,0.04));
      font-weight: 600;
    }
    .pb-content img {
      max-width: 100%;
      height: auto;
      border-radius: 6px;
    }
    .pb-content strong { font-weight: 600; }
    .pb-content em { font-style: italic; }

    .pb-footer {
      margin-top: 3rem;
      padding: 1rem;
      border-top: 1px solid oklch(var(--b3, 90% 0.01 0));
      font-size: 0.75rem;
      color: oklch(var(--bc, 20% 0.02 0) / 0.6);
      text-align: center;
    }

    .pb-footer a {
      color: inherit;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <article class="pb-content">
    {{ body_html }}
  </article>

  <footer class="pb-footer">
    Generated by <strong>atv-paperboard</strong> &mdash;
    <a href="{{ design_md_path | e }}" target="_blank" rel="noopener">DESIGN.md</a>
  </footer>
</body>
</html>
