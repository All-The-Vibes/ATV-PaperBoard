<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title | e }}</title>
  <!-- Tailwind CDN (play.cdn.tailwindcss.com for dev; replace with bundled for prod) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- daisyUI via CDN -->
  <link
    href="https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css"
    rel="stylesheet"
    type="text/css"
  />
  <style>
    /* ── Token overrides injected by atv-paperboard render layer ── */
    :root {
{% for var, value in tokens.items() %}
      {{ var }}: {{ value }};
{% endfor %}
    }

    /* Map atv-paperboard daisy tokens onto daisyUI HSL vars */
    [data-theme="light"] {
{% for var, value in tokens.items() %}
      {{ var }}: {{ value }};
{% endfor %}
    }

    .pb-content {
      max-width: 1024px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .pb-footer {
      margin-top: 3rem;
      padding: 1rem;
      border-top: 1px solid oklch(var(--b3, 90% 0.01 0));
      font-size: 0.75rem;
      color: oklch(var(--bc, 20% 0.02 0) / 0.6);
      text-align: center;
    }

    .pb-footer a {
      color: inherit;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="pb-content">
    {{ body_html }}
  </div>

  <footer class="pb-footer">
    Generated by <strong>atv-paperboard</strong> &mdash;
    <a href="{{ design_md_path | e }}" target="_blank" rel="noopener">DESIGN.md</a>
  </footer>
</body>
</html>
