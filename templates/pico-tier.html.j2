<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title | e }}</title>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"
  />
  <style>
    /* ── Token overrides injected by atv-paperboard render layer ── */
    :root {
{% for var, value in tokens.items() %}
      {{ var }}: {{ value }};
{% endfor %}
    }

    body {
      padding: 0;
      margin: 0;
    }

    .pb-content {
      max-width: 1024px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .pb-footer {
      margin-top: 3rem;
      padding: 1rem;
      border-top: 1px solid var(--pico-muted-border-color, #e0e0e0);
      font-size: 0.75rem;
      color: var(--pico-muted-color, #666);
      text-align: center;
    }

    .pb-footer a {
      color: inherit;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <main class="pb-content">
    {{ body_html }}
  </main>

  <footer class="pb-footer">
    Generated by <strong>atv-paperboard</strong> &mdash;
    <a href="{{ design_md_path | e }}" target="_blank" rel="noopener">DESIGN.md</a>
  </footer>
</body>
</html>
