# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
venv/
.venv/
env/

# Node
node_modules/
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp
*.swo

# atv-paperboard runtime
~/.atv-paperboard/
paperboard-artifacts/
.atv-paperboard-cache/

# Session/research scratch (kept locally, not committed)
.omc/

# Teaser workstream (separate)
teaser/

# Release-proof harness — local-only validation artifacts, not part of the published repo
_release-proof/

# Spec docs — kept locally as internal reasoning record; not part of the published repo.
# All user-facing details live in README.md.
SPEC*.md

# Sub-agent worktree scratch (created by Agent tool isolation mode)
.claude/worktrees/

# Secrets — never commit. Use .env.example for documented templates and add `!.env.example` below if you ever need one tracked.
.env
.env.*
*.pem
*.key
secrets/

# General logs and backup files
*.log
*.bak
*.orig
*.rej

# Python tooling
.python-version
.ipynb_checkpoints/

# Neighboring AI coding tools' artifacts (paperboard runs alongside these)
**/copilot-session-*.md
**/copilot-session-*.json
**/.copilot/
.aider*
.cursor/
.codeium/
.continue/

# Scratch / temp
tmp/
temp/
*.tmp
.DS_Store?

# Build/test ephemera not yet covered above
*.tsbuildinfo
coverage/
.nyc_output/

# Adapter build outputs (per-adapter `_dist/` produced by build.py)
adapters/*/_dist/
